<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents.Mcp</RootNamespace>
        <PackageId>ANcpLua.Agents.Mcp</PackageId>
        <Description>Qyl-prefixed Model Context Protocol client facades for Microsoft Agent Framework consumers.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>maf;agents;microsoft-agents;mcp;model-context-protocol;client</PackageTags>
        <!--
            CA2000 cannot model IAsyncDisposable-only ownership transfer.
            ModelContextProtocol.Client.HttpClientTransport is IAsyncDisposable (no
            sync Dispose), and McpClient.CreateAsync(IClientTransport) takes ownership
            of the transport. The recommended dispose pattern (`x?.Dispose()` in
            finally with `transport = null` after transfer) is exactly what
            QylHttpMcpClient implements, but CA2000 only recognizes IDisposable.Dispose
            in the finally block — so it flags the new HttpClientTransport(...) site
            regardless. Same precedent as ANcpLua.Agents.Testing (FakeHttpMessageHandler).
        -->
        <NoWarn>$(NoWarn);CA2000</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Agents.AI"/>
        <PackageReference Include="Microsoft.Extensions.AI"/>
        <PackageReference Include="ModelContextProtocol"/>
    </ItemGroup>

</Project>
