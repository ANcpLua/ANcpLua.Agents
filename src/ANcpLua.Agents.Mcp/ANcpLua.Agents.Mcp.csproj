<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents.Mcp</RootNamespace>
        <PackageId>ANcpLua.Agents.Mcp</PackageId>
        <Description>Qyl-prefixed Model Context Protocol client facades for Microsoft Agent Framework consumers.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>maf;agents;microsoft-agents;mcp;model-context-protocol;client</PackageTags>
        <!--
            CA2000 false positive in QylHttpMcpClient: HttpClientTransport is
            IAsyncDisposable, and McpClient.CreateAsync(IClientTransport) takes ownership
            of it (the client disposes the transport on DisposeAsync). CA2000 cannot model
            that IAsyncDisposable ownership transfer, so it flags the
            `new HttpClientTransport(...)` site — disposing it locally would tear down the
            live transport. The StdioClientTransport bundle is unaffected.
        -->
        <NoWarn>$(NoWarn);CA2000</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Agents.AI"/>
        <PackageReference Include="Microsoft.Extensions.AI"/>
        <PackageReference Include="ModelContextProtocol"/>
    </ItemGroup>

</Project>
