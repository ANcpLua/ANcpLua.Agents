<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents</RootNamespace>
        <PackageId>ANcpLua.Agents</PackageId>
        <Description>Consumer toolkit spine for Microsoft Agent Framework. Bundling facades plus governance primitives: call lineage, spawn tracker, budget enforcer, concurrency limiter, governed AIFunction, tracing decorators, and tool-decorating chat client.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>maf;agents;microsoft-agents;governance;instrumentation;opentelemetry;helpers</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Agents.AI"/>
        <PackageReference Include="Microsoft.Agents.AI.Abstractions"/>
        <PackageReference Include="Microsoft.Extensions.AI"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
