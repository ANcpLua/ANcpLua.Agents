<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents</RootNamespace>
        <PackageId>ANcpLua.Agents</PackageId>
        <Description>Runtime helpers for Microsoft Agent Framework consumers. Governance primitives (call lineage, spawn tracker, budget enforcer, concurrency limiter, governed AIFunction), instrumentation decorators (traced AIFunction, tool-decorating chat client), an OpenAI-compatible chat-client factory, and console-rendering utilities for agent responses, tool calls, workflow events, and streaming output.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>maf;agents;microsoft-agents;governance;instrumentation;opentelemetry;helpers;console;workflows</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Agents.AI"/>
        <PackageReference Include="Microsoft.Agents.AI.Workflows"/>
        <PackageReference Include="Microsoft.Extensions.AI"/>
        <PackageReference Include="Microsoft.Extensions.AI.OpenAI"/>
        <PackageReference Include="OpenAI"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\"/>
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
