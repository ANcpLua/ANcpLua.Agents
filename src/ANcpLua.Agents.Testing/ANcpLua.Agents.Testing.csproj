<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents.Testing</RootNamespace>
        <PackageId>ANcpLua.Agents.Testing</PackageId>
        <Description>Test infrastructure for Microsoft Agent Framework. Fake agents, scripted chat clients, SSE parsing, mock HTTP handlers, and IChatClientAgentFixture reference implementations for OpenAI, Azure OpenAI, Anthropic, Ollama, Google Gemini, and OpenRouter.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>agent;testing;sse;mock;streaming;microsoft-agents;conformance</PackageTags>
        <!-- Conformance/ mirrors microsoft/agent-framework upstream; not reformatted to satisfy these rules. -->
        <NoWarn>$(NoWarn);CA2000;IDE0059;IDE0060;IDE1006</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Agents.AI"/>
        <PackageReference Include="Microsoft.Agents.AI.Abstractions"/>
        <PackageReference Include="xunit.v3.extensibility.core"/>
        <PackageReference Include="xunit.v3.assert"/>
        <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing"/>
        <PackageReference Include="OpenAI"/>
        <PackageReference Include="Microsoft.Extensions.AI.OpenAI"/>
        <PackageReference Include="Moq"/>
    </ItemGroup>

    <ItemGroup Label="Conformance provider SDKs">
        <PackageReference Include="Azure.AI.OpenAI"/>
        <PackageReference Include="Azure.Identity"/>
        <PackageReference Include="Anthropic.SDK"/>
        <PackageReference Include="OllamaSharp"/>
        <PackageReference Include="Google.GenAI"/>
    </ItemGroup>

    <ItemGroup>
        <Using Include="System.Text"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\"/>
    </ItemGroup>

</Project>
