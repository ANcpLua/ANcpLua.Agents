<Project Sdk="ANcpLua.NET.Sdk">
    <PropertyGroup>
        <RootNamespace>ANcpLua.Agents.Mcp.Hosting</RootNamespace>
        <PackageId>ANcpLua.Agents.Mcp.Hosting</PackageId>
        <Description>Qyl-prefixed Model Context Protocol server hosting facades for Microsoft Agent Framework consumers.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>maf;agents;microsoft-agents;mcp;model-context-protocol;hosting;aspnetcore</PackageTags>
        <!--
            MCPEXP001 is the MCP SDK's experimental-API marker covering the
            long-running task lifecycle (IMcpTaskStore, InMemoryMcpTaskStore,
            McpServerOptions.TaskStore). QylMcpTaskStoreExtensions.WithInMemoryTaskStore
            wires the in-memory store onto the server-builder chain as the
            user-facing payoff for adopting the experimental surface — the
            extension IS the abstraction layer that isolates consumers from
            churn. Revisit when the MCP SDK promotes the task API to stable.
            Same precedent as the existing entry in ANcpLua.Agents.Mcp.csproj
            that suppresses MCPEXP001 for QylMcpTaskExtensions.RunQylToolAsTaskAsync.
        -->
        <NoWarn>$(NoWarn);MCPEXP001</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
        <PackageReference Include="ANcpLua.Roslyn.Utilities"/>
        <PackageReference Include="Microsoft.Extensions.AI"/>
        <PackageReference Include="ModelContextProtocol.AspNetCore"/>
        <!--
            JwtBearer.dll is NOT included in the Microsoft.AspNetCore.App.Ref shared
            framework. Required by QylMcpOAuthExtensions.WithQylOAuthProtectedResource
            which wires AddJwtBearer + AddMcp.AddProtectedResource for OAuth 2.1
            protected-resource discovery. Verified empirically in the 10.0.7 ref pack.
        -->
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\ANcpLua.Agents.Mcp\ANcpLua.Agents.Mcp.csproj"/>
    </ItemGroup>

</Project>
