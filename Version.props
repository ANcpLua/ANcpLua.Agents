<Project>
  <!--
    ═══════════════════════════════════════════════════════════════════════════
    ANcpLua.Agents - Centralized version variables (MAF + test infrastructure)
    ═══════════════════════════════════════════════════════════════════════════

    Scope: packages referenced across ANcpLua.Agents* projects only. Foundation
    Roslyn helpers live in ANcpLua.Roslyn.Utilities and are consumed here via
    ordinary <PackageReference> with pinned versions (Serilog-style polyrepo).
  -->

  <PropertyGroup Label=".NET SDK">
    <DotNetSdkVersion>10.0.202</DotNetSdkVersion>
  </PropertyGroup>

  <PropertyGroup Label="Roslyn.Utilities (consumed from sibling repo)">
    <ANcpLuaRoslynUtilitiesVersion>1.56.1</ANcpLuaRoslynUtilitiesVersion>
    <ANcpLuaRoslynUtilitiesTestingVersion>1.56.1</ANcpLuaRoslynUtilitiesTestingVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Agents (MAF 1.2)">
    <!-- Stable 1.2.0: core, abstractions, workflows, OpenAI, Foundry -->
    <MicrosoftAgentsAIVersion>1.2.0</MicrosoftAgentsAIVersion>
    <MicrosoftAgentsAIWorkflowsVersion>1.2.0</MicrosoftAgentsAIWorkflowsVersion>
    <!-- Preview 1.2.0-preview.260421.1: Hosting (no stable exists), AGUI, Anthropic, A2A, hosting satellites -->
    <MicrosoftAgentsAIHostingVersion>1.2.0-preview.260421.1</MicrosoftAgentsAIHostingVersion>
    <MicrosoftAgentsAIHostingAGUIAspNetCoreVersion>1.2.0-preview.260421.1</MicrosoftAgentsAIHostingAGUIAspNetCoreVersion>
    <MicrosoftAgentsAIAnthropicVersion>1.2.0-preview.260421.1</MicrosoftAgentsAIAnthropicVersion>
    <!-- rc1: Declarative workflows (separate train from core 1.2) -->
    <MicrosoftAgentsAIWorkflowsDeclarativeVersion>1.2.0-rc1</MicrosoftAgentsAIWorkflowsDeclarativeVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Extensions.AI">
    <MicrosoftExtensionsAIVersion>10.5.0</MicrosoftExtensionsAIVersion>
    <MicrosoftExtensionsAIAbstractionsVersion>10.5.0</MicrosoftExtensionsAIAbstractionsVersion>
    <MicrosoftExtensionsAIOpenAIVersion>10.5.0</MicrosoftExtensionsAIOpenAIVersion>
    <MicrosoftBclAsyncInterfacesVersion>10.0.6</MicrosoftBclAsyncInterfacesVersion>
  </PropertyGroup>

  <PropertyGroup Label="LLM Provider SDKs (AgentTesting Conformance/Examples fixtures)">
    <OpenAIVersion>2.10.0</OpenAIVersion>
    <AzureAIOpenAIVersion>2.1.0</AzureAIOpenAIVersion>
    <AzureIdentityVersion>1.21.0</AzureIdentityVersion>
    <AnthropicSDKVersion>5.10.0</AnthropicSDKVersion>
    <OllamaSharpVersion>5.4.25</OllamaSharpVersion>
    <GoogleGenAIVersion>1.6.1</GoogleGenAIVersion>
  </PropertyGroup>

  <PropertyGroup Label="Testing">
    <XunitV3Version>3.2.2</XunitV3Version>
    <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
    <MTPExtensionsVersion>2.1.0</MTPExtensionsVersion>
    <MoqVersion>4.20.72</MoqVersion>
  </PropertyGroup>

  <PropertyGroup Label="Roslyn (Microsoft.CodeAnalysis.CSharp for SyntaxTreeFluentExtensions)">
    <RoslynVersion>5.3.0</RoslynVersion>
    <RoslynAnalyzersVersion>5.3.0</RoslynAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="ASP.NET Core (Microsoft.AspNetCore.Mvc.Testing — AgentTesting Hosting/ folder)">
    <AspNetCoreVersion>10.0.6</AspNetCoreVersion>
  </PropertyGroup>
</Project>
