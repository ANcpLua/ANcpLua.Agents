<Project>
  <!--
    LOCAL OVERRIDE — ANcpLua.Agents

    Imported by Directory.Packages.props at the top, BEFORE the SDK-shipped
    Version.props is in scope (the SDK only imports its own Version.props
    once a project enters <Project Sdk="ANcpLua.NET.Sdk">). Therefore this
    file must define every $(...Version) variable that Directory.Packages.props
    references — pruning to "ahead-only" breaks restore.

    Values mirror SDK truth (numeric base 1.6.1; experimental tracks where
    upstream ships them). Deviations from truth:
      - Google.GenAI (not in truth)
  -->

  <PropertyGroup Label="Roslyn.Utilities (consumed from sibling repo)">
    <ANcpLuaRoslynUtilitiesVersion>2.2.5</ANcpLuaRoslynUtilitiesVersion>
    <ANcpLuaRoslynUtilitiesTestingVersion>2.2.5</ANcpLuaRoslynUtilitiesTestingVersion>
    <ANcpLuaRoslynUtilitiesSourcesVersion>2.2.5</ANcpLuaRoslynUtilitiesSourcesVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Agents (MAF 1.6.1 — mirrors SDK truth, highest experimental track per package)">
    <!-- Stable: core, Workflows, OpenAI (Foundry moved to preview-only in 1.6.1) -->
    <MicrosoftAgentsAIVersion>1.6.1</MicrosoftAgentsAIVersion>
    <MicrosoftAgentsAIWorkflowsVersion>1.6.1</MicrosoftAgentsAIWorkflowsVersion>
    <MicrosoftAgentsAIOpenAIVersion>1.6.1</MicrosoftAgentsAIOpenAIVersion>
    <!-- Preview (no stable exists): Foundry, Hosting, AzureFunctions, Foundry.Hosting, Anthropic, DevUI, Harness, AGUI, A2A -->
    <MicrosoftAgentsAIFoundryVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIFoundryVersion>
    <MicrosoftAgentsAIHostingVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHostingVersion>
    <MicrosoftAgentsAIHostingAzureFunctionsVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHostingAzureFunctionsVersion>
    <MicrosoftAgentsAIFoundryHostingVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIFoundryHostingVersion>
    <MicrosoftAgentsAIAnthropicVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIAnthropicVersion>
    <MicrosoftAgentsAIDevUIVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIDevUIVersion>
    <MicrosoftAgentsAIHarnessVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHarnessVersion>
    <MicrosoftAgentsAIAGUIVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIAGUIVersion>
    <MicrosoftAgentsAIHostingAGUIAspNetCoreVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHostingAGUIAspNetCoreVersion>
    <MicrosoftAgentsAIA2AVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIA2AVersion>
    <MicrosoftAgentsAIHostingA2AVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHostingA2AVersion>
    <MicrosoftAgentsAIHostingA2AAspNetCoreVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIHostingA2AAspNetCoreVersion>
    <!-- rc1 train: Declarative workflows -->
    <MicrosoftAgentsAIWorkflowsDeclarativeVersion>1.6.1-rc1</MicrosoftAgentsAIWorkflowsDeclarativeVersion>
    <MicrosoftAgentsAIWorkflowsDeclarativeFoundryVersion>1.6.1-rc1</MicrosoftAgentsAIWorkflowsDeclarativeFoundryVersion>
    <!-- Alpha train: OpenAI hosting -->
    <MicrosoftAgentsAIHostingOpenAIVersion>1.6.1-alpha.260514.1</MicrosoftAgentsAIHostingOpenAIVersion>
    <!-- Preview train: DurableTask integration (Qyl.DurableAgents host) -->
    <MicrosoftAgentsAIDurableTaskVersion>1.6.1-preview.260514.1</MicrosoftAgentsAIDurableTaskVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.DurableTask (host-agnostic worker + client; gRPC sidecar backend)">
    <MicrosoftDurableTaskGrpcVersion>1.24.1</MicrosoftDurableTaskGrpcVersion>
  </PropertyGroup>

  <PropertyGroup Label="ManagedAgentTelemetry.Host sample (Foundry persistent agents + Teams + RAG + AzMon)">
    <AzureAIProjectsVersion>2.1.0-beta.1</AzureAIProjectsVersion>
    <MicrosoftGraphVersion>5.104.0</MicrosoftGraphVersion>
    <AzureSearchDocumentsVersion>11.7.0</AzureSearchDocumentsVersion>
    <AzureMonitorOpenTelemetryAspNetCoreVersion>1.4.0</AzureMonitorOpenTelemetryAspNetCoreVersion>
  </PropertyGroup>

  <PropertyGroup Label="Microsoft.Extensions.AI">
    <MicrosoftExtensionsAIVersion>10.5.2</MicrosoftExtensionsAIVersion>
    <MicrosoftExtensionsAIAbstractionsVersion>10.5.2</MicrosoftExtensionsAIAbstractionsVersion>
    <MicrosoftExtensionsAIOpenAIVersion>10.5.2</MicrosoftExtensionsAIOpenAIVersion>
    <MicrosoftBclAsyncInterfacesVersion>10.0.7</MicrosoftBclAsyncInterfacesVersion>
  </PropertyGroup>

  <PropertyGroup Label="A2A (Agent2Agent protocol SDK — a2aproject/a2a-dotnet)">
    <A2AVersion>1.0.0-preview2</A2AVersion>
    <A2AAspNetCoreVersion>1.0.0-preview2</A2AAspNetCoreVersion>
  </PropertyGroup>

  <PropertyGroup Label="ModelContextProtocol (MCP SDK — modelcontextprotocol/csharp-sdk)">
    <ModelContextProtocolVersion>1.3.0</ModelContextProtocolVersion>
    <ModelContextProtocolAspNetCoreVersion>1.3.0</ModelContextProtocolAspNetCoreVersion>
  </PropertyGroup>

  <PropertyGroup Label="LLM Provider SDKs (AgentTesting Conformance/Examples fixtures)">
    <OpenAIVersion>2.10.0</OpenAIVersion>
    <AzureAIOpenAIVersion>2.1.0</AzureAIOpenAIVersion>
    <AzureIdentityVersion>1.21.0</AzureIdentityVersion>
    <AnthropicSDKVersion>5.10.0</AnthropicSDKVersion>
    <OllamaSharpVersion>5.4.25</OllamaSharpVersion>
    <GoogleGenAIVersion>1.6.1</GoogleGenAIVersion>
  </PropertyGroup>

  <PropertyGroup Label="Testing">
    <XunitV3Version>3.2.2</XunitV3Version>
    <AwesomeAssertionsVersion>9.4.0</AwesomeAssertionsVersion>
    <MTPExtensionsVersion>2.1.0</MTPExtensionsVersion>
    <MoqVersion>4.20.72</MoqVersion>
  </PropertyGroup>

  <PropertyGroup Label="Roslyn (SyntaxTreeFluentExtensions + analyzer framework)">
    <RoslynVersion>5.3.0</RoslynVersion>
    <RoslynAnalyzersVersion>5.3.0</RoslynAnalyzersVersion>
  </PropertyGroup>

  <PropertyGroup Label="ASP.NET Core (Microsoft.AspNetCore.Mvc.Testing — AgentTesting Hosting/ folder)">
    <AspNetCoreVersion>10.0.7</AspNetCoreVersion>
  </PropertyGroup>
</Project>
