<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>ANcpLua.Agents.Tests</RootNamespace>
        <IsPackable>false</IsPackable>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <!--
            CA1707 — underscores in identifiers: convention for test names (Method_Condition_Expected).
            xUnit1051 — TestContext.Current.CancellationToken: stylistic, not bug-catching.
            CS1591  — XML doc comments not required on test methods.
        -->
        <NoWarn>$(NoWarn);CS1591;CA1707;xUnit1051</NoWarn>
        <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
        <!-- xunit.v3 brings its own Microsoft.Testing.Platform graph; the central 2.1.0 pin
             collides with the 1.x version expected by xunit's MSBuild extension. Let xunit
             pick the matching transitive. -->
        <CentralPackageTransitivePinningEnabled>false</CentralPackageTransitivePinningEnabled>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="xunit.v3"/>
        <PackageReference Include="AwesomeAssertions"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\ANcpLua.Agents\ANcpLua.Agents.csproj"/>
    </ItemGroup>

    <ItemGroup Label="Analyzers">
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all"/>
    </ItemGroup>
</Project>
